# Backend runtime
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=cavistamed_ai
JWT_SECRET_KEY=change-this-in-production
JWT_EXPIRE_MINUTES=1440

# Gemini entity extraction (optional but recommended)
# If GEMINI_API_KEY is not set, backend falls back to local Ollama and then heuristics.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
